---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Heading from "~/components/Heading.astro";
import FormContact from "~/components/forms/FormContact.astro";
import { getLangFromUrl } from "astro:i18n";
import { translations } from "~/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = translations[lang];
---

<Layout title={t.nav.contact} pageTitle={t.nav.contact}>
	<Section>
		<Heading>
			<h2 slot="heading-title" class="font-black text-brand-green h2">{t.nav.contact}</h2>
			<p slot="heading-content">
				{lang === 'hr'
					? 'Kontaktirajte nas za sva pitanja ili upite.'
					: 'Get in touch with us for any questions or inquiries.'}
			</p>
		</Heading>

        <FormContact />
		
	</Section>
</Layout>