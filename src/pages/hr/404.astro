---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import { getLangFromUrl } from "astro:i18n";
import { translations } from "~/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = translations[lang];
---

<Layout title={t.common.notFound}>
	<Section>
		<div class="min-h-full mx-auto w-full max-w-6xl">
			<div class="text-center">
				<p class="font-bold text-brand-red text-8xl">404</p>
				<h1 class="mt-8 text-4xl font-black text-balance lg:text-5xl">
					{lang === 'hr' ? 'Ova stranica nije pronađena.' : 'This page could not be found.'}
				</h1>
				<p class="mt-6 text-base text-balance">
					{lang === 'hr'
						? 'Možda ste pogrešno upisali adresu ili se stranica preselila.'
						: 'You may have mistyped the address or the page may have moved.'}
				</p>
				<div class="mt-16">
					<a href={lang === 'hr' ? '/' : '/en/'} class="button button-green">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 20 20"
							fill="currentColor"
							class="size-4 inline-block -mt-0.5 mr-1"
						>
							<path
								fill-rule="evenodd"
								d="M9.293 2.293a1 1 0 0 1 1.414 0l7 7A1 1 0 0 1 17 11h-1v6a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-6H3a1 1 0 0 1-.707-1.707l7-7Z"
								clip-rule="evenodd"></path>
						</svg>
						{lang === 'hr' ? 'Početna' : 'Go Home'}
					</a>
				</div>
			</div>
		</div>
	</Section>
</Layout>