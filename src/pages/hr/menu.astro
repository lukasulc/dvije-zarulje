---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Heading from "~/components/Heading.astro";
import MenuList from "~/components/Menu.astro";
import { getLangFromUrl } from "astro:i18n";
import { translations } from "~/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = translations[lang];
---

<Layout title={t.nav.menu} pageTitle={t.nav.menu}>
	<Section>
		<Heading>
			<h1 slot="heading-title" class="font-black text-brand-green h2">{t.nav.menu}</h1>
			<p slot="heading-content">
				{lang === 'hr'
					? 'Nudimo raznovrsna jela, od tradicionalnih do modernih, koja će zadovoljiti vaše želje.'
					: 'We offer a variety of dishes, from traditional to modern, that are sure to satisfy your cravings.'}
			</p>
		</Heading>

		<MenuList />
	</Section>
</Layout>