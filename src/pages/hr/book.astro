---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Heading from "~/components/Heading.astro";
import FormBook from "~/components/forms/FormBook.astro";
import { getLangFromUrl } from "astro:i18n";
import { translations } from "~/i18n/translations";

const lang = getLangFromUrl(Astro.url);
const t = translations[lang];
---

<Layout title={t.nav.book} pageTitle={t.nav.book}>
	<Section>
		<Heading>
			<h2 slot="heading-title" class="font-black text-brand-green h2">{t.nav.book}</h2>
			<p slot="heading-content" class="text-pretty">
				{lang === 'hr'
					? 'Rezervirajte stol za vaš sljedeći obrok. Javiti ćemo vam se potvrdom rezervacije.'
					: 'Reserve a table for your next meal. We\'ll get back to you to confirm your booking.'}
			</p>
		</Heading>

		<FormBook />
	</Section>
</Layout>